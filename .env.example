# Copy to .env and fill in values — NEVER commit .env to source control.
# .env is in .gitignore.

PORT=8080

# ── Database (two-role pattern per ADR-002) ────────────────────────────────
# For local dev both can point to postgres superuser.
# In production: DB_MIGRATOR_URL → rimi_migrator (DDL perms), DB_APP_URL → rimi_app (DML only).
DB_MIGRATOR_URL=postgres://postgres:postgres@db:5432/rimi?sslmode=disable
DB_APP_URL=postgres://postgres:postgres@db:5432/rimi?sslmode=disable

# ── JWT (RS256 keys — generate once, store in secrets manager) ─────────────
# Generate:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
# Then copy the full PEM content (including BEGIN/END lines) into the vars below.
# Multi-line values must be quoted or use \n escaping when set via `export`.
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_ISSUER=rimi-auth
JWT_AUDIENCE=rimi-api
JWT_KEY_ID=k1
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL=720h

# ── SMTP ───────────────────────────────────────────────────────────────────
# For local dev, run Mailpit: docker run -p 1025:1025 -p 8025:8025 axllent/mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@rimi.app

# ── Auth lockout ───────────────────────────────────────────────────────────
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION=15m

# ── Token TTLs ─────────────────────────────────────────────────────────────
EMAIL_VERIFY_TTL=24h
PASSWORD_RESET_TTL=30m

# ── Migrations ────────────────────────────────────────────────────────────
# Default: file://migrations (relative to the binary's working directory).
# Do not change unless you move the migrations/ folder.
MIGRATIONS_PATH=file://migrations
