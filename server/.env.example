# Copy this to .env and fill in real values. NEVER commit .env.
# SECRETS-01: all secrets from env only.

PORT=8080

# Two DB roles per ADR-002
DB_MIGRATOR_URL=postgres://rimi_migrator:changeme@localhost:5432/rimi?sslmode=disable
DB_MIGRATOR_PASSWORD=changeme

DB_APP_URL=postgres://rimi_app:changeme2@localhost:5432/rimi?sslmode=disable
DB_APP_PASSWORD=changeme2

# RS256 keys — generate with: scripts/gen-keys.sh
# Auth-10: never commit private key.
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

JWT_ISSUER=rimi-auth
JWT_AUDIENCE=rimi-api
JWT_KEY_ID=k1
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL=720h

# Email (Mailpit for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@rimi.app

# Auth lockout
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION=15m

# Email token TTLs
EMAIL_VERIFY_TTL=24h
PASSWORD_RESET_TTL=30m

MIGRATIONS_PATH=file://migrations
